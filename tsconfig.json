{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    "ignoreDeprecations": "6.0",
    "baseUrl": ".",

    "paths": {
      "@/*": ["./assets/src/*"],
      "@app/*": ["./assets/src/*"],
      "@utils/*": ["./assets/src/utils/*"],
      "@styles/*": ["./assets/src/styles/*"],
      "@core/*": ["./assets/src/core/*"],
      "@admin/*": ["./assets/src/admin/*"],
      "@core-ui/*": ["./assets/src/core-ui/*"],
      "@frontend/*": ["./assets/src/frontend/*"],

      /** 🔥 AJOUT IMPORTANT */
      "@transactions/*": ["./assets/src/features/transactions/*"]
    }
  },
  "include": ["assets/src"]
}